{
  "name": "mini-claw-code-ts-workspace",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "mini-claw-code-ts",
    "mini-claw-code-starter-ts"
  ],
  "devDependencies": {
    "@types/node": "^24.6.1",
    "bun-types": "^1.3.5",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "typecheck": "bun run --cwd mini-claw-code-ts typecheck && bun run --cwd mini-claw-code-starter-ts typecheck",
    "test": "bun test mini-claw-code-ts/src/tests mini-claw-code-ts/tests",
    "test:starter": "bun test mini-claw-code-starter-ts/tests",
    "book:ts": "mdbook build mini-claw-code-book-ts"
  }
}
